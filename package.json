{
  "name": "ulyzer",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered personal knowledge graph learning tool",
  "main": "./out/main/index.js",
  "author": "seethith",
  "homepage": "https://github.com/seethith/Ulyzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seethith/Ulyzer.git"
  },
  "bugs": {
    "url": "https://github.com/seethith/Ulyzer/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && npm run check:i18n && electron-vite build",
    "build:swift": "node scripts/build-swift.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build:swift && npm run build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "check:i18n": "node scripts/check-i18n.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@lezer/markdown": "^1.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@mozilla/readability": "^0.6.0",
    "@types/semver": "^7.7.1",
    "allotment": "^1.20.5",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^5.6.0",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.6",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "keytar": "^7.9.0",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.2",
    "reactflow": "^11.11.4",
    "semver": "^7.8.1",
    "tailwindcss": "^4.2.2",
    "tiktoken": "^1.0.22",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13"
  }
}
